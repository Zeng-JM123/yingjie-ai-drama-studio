# Public HTTPS hostname for the gateway. Its A record must point to the ECS EIP.
GATEWAY_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# Private secret: set this only on the ECS instance, never in GitHub or this example.
ARK_API_KEY=
# Fill these only after opening the corresponding model in the Ark Console.
ARK_TEXT_MODEL_TURBO=
ARK_TEXT_MODEL_PRO=
ARK_TEXT_MODEL_EVOLVING=
ARK_TEXT_MODEL_DEEPSEEK=
ARK_TEXT_MODEL_KIMI=
ARK_TEXT_MODEL_GLM=
ARK_TEXT_MODELS_JSON=[]
ARK_TEXT_MAX_TOKENS=24000
ARK_TEXT_TIMEOUT_MS=240000
ARK_VIDEO_ENDPOINT_ID=ep-20260712014412-l4ncj
# Required for a public gateway. Generate a long random value on the ECS; the
# operator enters it in the browser when first opening the studio.
STUDIO_ACCESS_TOKEN=

# Exact GitHub Pages origin only; no trailing slash and no page path.
CORS_ORIGINS=https://zeng-jm123.github.io
JOB_LIMIT_MAX=3
JOB_LIMIT_WINDOW_SECONDS=300

# Caddy is the only reverse proxy in this deployment and sets X-Forwarded-For.
TRUST_PROXY=true
ALLOW_LOOPBACK_ORIGINS=false
# Keep false for public deployments; only enable when intentionally supporting file:// previews.
ALLOW_FILE_ORIGIN=false
