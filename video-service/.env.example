# Server only. Never copy this key to GitHub Pages or a browser-side file.
ARK_API_KEY=
# Fill these only after opening the corresponding model in the Ark Console.
ARK_TEXT_MODEL_TURBO=
ARK_TEXT_MODEL_PRO=
ARK_TEXT_MODEL_EVOLVING=
ARK_TEXT_MODEL_DEEPSEEK=
ARK_TEXT_MODEL_KIMI=
ARK_TEXT_MODEL_GLM=
# Add any other Ark Model ID or Endpoint ID as a JSON array. Keep it server-side.
ARK_TEXT_MODELS_JSON=[]
ARK_TEXT_MAX_TOKENS=24000
# Structured production output can take longer than a normal chat response.
ARK_TEXT_TIMEOUT_MS=240000
ARK_VIDEO_ENDPOINT_ID=ep-20260712014412-l4ncj
# Required in public deployments. Generate a long random value and enter it in
# the browser only when prompted; never put it in runtime-config.js.
STUDIO_ACCESS_TOKEN=
CORS_ORIGINS=https://zeng-jm123.github.io,http://localhost:4173,http://127.0.0.1:4173,http://localhost:8000,http://127.0.0.1:8000
PORT=8787
# One IP may create at most this many jobs within the time window. Use a shared
# store and authenticated users for a multi-instance production deployment.
JOB_LIMIT_MAX=3
JOB_LIMIT_WINDOW_SECONDS=300
# Set to true only when a trusted reverse proxy overwrites X-Forwarded-For.
TRUST_PROXY=false
# Local development only. Keep false in a public deployment and list exact origins above.
ALLOW_LOOPBACK_ORIGINS=false
# Local development only: allow opening index.html directly with a file:// URL.
ALLOW_FILE_ORIGIN=false
DATABASE_PATH=./data/yingjie.db
